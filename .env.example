# Nuvela environment variables (TRD §Environment Variables).
# Copy to backend/.env (and frontend/.env.local where relevant). Real values are never committed.

# --- Database (Supabase) ---
DATABASE_URL=            # pooled (PgBouncer) connection — runtime queries
DIRECT_URL=              # direct connection — migrations

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Supabase Storage ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # backend-only; issues signed URLs for private buckets

# --- Email (Resend) ---
RESEND_API_KEY=

# --- AI Assistant (NVIDIA NIM) — backend only ---
NVIDIA_API_KEY=            # required for /assistant/chat; from https://build.nvidia.com
NVIDIA_BASE_URL=           # optional; default https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=              # optional; default deepseek-ai/deepseek-v4-flash

# --- URLs / CORS ---
FRONTEND_URL=            # CORS origins (comma-separated) + primary email link base
BACKEND_URL=             # API base for the client + email links

# --- Runtime ---
NODE_ENV=development

# --- Frontend (client-readable) ---
NEXT_PUBLIC_BACKEND_URL=   # the NestJS backend base URL (Render); used by the browser
