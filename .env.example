# Nuvela environment variables (TRD §Environment Variables).
# Copy to backend/.env (and frontend/.env.local where relevant). Real values are never committed.

# --- Database (Supabase) ---
DATABASE_URL=            # pooled (PgBouncer) connection — runtime queries
DIRECT_URL=              # direct connection — migrations

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Supabase Storage ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # backend-only; issues signed URLs for private buckets

# --- Email (Resend) ---
RESEND_API_KEY=

# --- URLs / CORS ---
FRONTEND_URL=            # CORS origin + cookie domain + email links
BACKEND_URL=             # API base for the client + email links

# --- Runtime ---
NODE_ENV=development
